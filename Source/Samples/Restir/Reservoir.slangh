struct RestirSample
{
    float3 geometryPos;
    float3 lightSamplePosition;
    float3 incomingRadiance;
};

struct RestirReservoir
{
    RestirSample m_y;
    float m_Wsum;
    uint m_M;
    float m_W;
};

void initReservoir(inout RestirReservoir r)
{
    r.m_Wsum = 0.0f;
    r.m_M = 0;
    r.m_W = 0.0f;
}
